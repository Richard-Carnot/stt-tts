VEXYL_STT_HOST=127.0.0.1
VEXYL_STT_PORT=8091
VEXYL_STT_DECODE=ctc
VEXYL_STT_DEVICE=cpu
# VEXYL_STT_API_KEY=your-secret-here

# English ASR Model (Phase 1)
VEXYL_STT_EN_ENABLED=true
VEXYL_STT_EN_MODEL=distil-whisper/distil-medium.en

# Spoken Language Identification (Phase 2)
VEXYL_STT_LID_ENABLED=true
VEXYL_STT_LID_MODEL=onecxi/vakgyata-base
VEXYL_STT_LID_MIN_CONFIDENCE=0.3
VEXYL_STT_LID_EN_THRESHOLD=0.85
VEXYL_STT_LID_SESSION_LOCK=true
